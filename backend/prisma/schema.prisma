// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String     @id @default(uuid())
  companyName String
  subdomain   String     @unique
  logoUrl     String?
  isActive    Boolean    @default(true)
  industry    Industry   @default(OTHERS)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]
  deliveries  Delivery[]
}

enum Industry {
  FOOD
  HEALTH
  TRANSPORT
  FASHION
  SPORT
  ENTERTAINMENT
  BANKING
  OTHERS
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  role          Role           @default(CUSTOMER)
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  driverProfile DriverProfile?
  deliveries    Delivery[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DriverProfile {
  id            String     @id @default(uuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id])
  vehicleType   String     // BIKE, VAN, TRUCK
  licenseNumber String
  isVerified    Boolean    @default(false)
  isOnline      Boolean    @default(false)
  lastLatitude  Float?     // last known latitude of the driver (updated dynamically)
  lastLongitude Float?     // last known longitude of the driver (updated dynamically)
  deliveries    Delivery[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Delivery {
  id                      String         @id @default(uuid())
  tenantId                String
  tenant                  Tenant         @relation(fields: [tenantId], references: [id])
  senderId                String
  sender                  User           @relation(fields: [senderId], references: [id])
  driverId                String?
  driver                  DriverProfile? @relation(fields: [driverId], references: [id])
  status                  DeliveryStatus @default(PENDING)
  pickupAddress           String
  pickupLatitude          Float
  pickupLongitude         Float
  senderPhone             String
  dropoffAddress          String
  dropoffLatitude         Float
  dropoffLongitude        Float
  recipientName           String
  recipientPhone          String
  deliveryOtp             String
  proofOfDeliveryPhotoUrl String?
  signaturePhotoUrl       String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

enum Role {
  CUSTOMER
  DRIVER
  ADMIN
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}



